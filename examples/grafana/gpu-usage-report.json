    {
      "id": 8,
      "type": "table",
      "title": "GPU usage KPI table, selected range",
      "description": "Long-form counter-based table: one row per host/GPU/KPI. Export this panel CSV for management reports.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "inspect": false
          }
        },
        "overrides": []
      },
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "editorMode": "code",
          "expr": "label_replace((increase(gpu_utilization_weighted_seconds_total{hostname=~\"$hostname\", gpu_index=~\"$gpu\"}[$__range]) / $__range_s * 100), \"kpi\", \"calendar_avg_util_percent\", \"hostname\", \".*\")\nor\nlabel_replace((increase(gpu_active_seconds_total{hostname=~\"$hostname\", gpu_index=~\"$gpu\"}[$__range]) / $__range_s * 100), \"kpi\", \"active_time_percent\", \"hostname\", \".*\")\nor\nlabel_replace((increase(gpu_active_seconds_total{hostname=~\"$hostname\", gpu_index=~\"$gpu\"}[$__range]) / 3600), \"kpi\", \"active_hours\", \"hostname\", \".*\")\nor\nlabel_replace((increase(gpu_utilization_weighted_seconds_total{hostname=~\"$hostname\", gpu_index=~\"$gpu\"}[$__range]) / 3600), \"kpi\", \"equivalent_gpu_hours_100pct\", \"hostname\", \".*\")\nor\nlabel_replace((increase(gpu_utilization_weighted_seconds_total{hostname=~\"$hostname\", gpu_index=~\"$gpu\"}[$__range]) / clamp_min(increase(gpu_active_seconds_total{hostname=~\"$hostname\", gpu_index=~\"$gpu\"}[$__range]), 1) * 100), \"kpi\", \"avg_util_while_active_percent\", \"hostname\", \".*\")\nor\nlabel_replace((max_over_time(gpu_utilization_percent{hostname=~\"$hostname\", gpu_index=~\"$gpu\"}[$__range])), \"kpi\", \"peak_util_percent\", \"hostname\", \".*\")\nor\nlabel_replace((quantile_over_time(0.95, gpu_utilization_percent{hostname=~\"$hostname\", gpu_index=~\"$gpu\"}[$__range])), \"kpi\", \"p95_util_percent\", \"hostname\", \".*\")\nor\nlabel_replace((increase(gpu_request_count_total{hostname=~\"$hostname\", gpu_index=~\"$gpu\"}[$__range])), \"kpi\", \"inferred_gpu_activity_windows\", \"hostname\", \".*\")\nor\nlabel_replace((increase(gpu_tensor_active_weighted_seconds_total{hostname=~\"$hostname\", gpu_index=~\"$gpu\"}[$__range]) / $__range_s), \"kpi\", \"calendar_avg_tensor_active_ratio\", \"hostname\", \".*\")\nor\nlabel_replace((increase(gpu_tensor_active_weighted_seconds_total{hostname=~\"$hostname\", gpu_index=~\"$gpu\"}[$__range]) / 3600), \"kpi\", \"tensor_active_hours\", \"hostname\", \".*\")\nor\nlabel_replace((increase(gpu_sm_active_weighted_seconds_total{hostname=~\"$hostname\", gpu_index=~\"$gpu\"}[$__range]) / 3600), \"kpi\", \"sm_active_hours\", \"hostname\", \".*\")\nor\nlabel_replace((increase(gpu_dram_active_weighted_seconds_total{hostname=~\"$hostname\", gpu_index=~\"$gpu\"}[$__range]) / 3600), \"kpi\", \"dram_active_hours\", \"hostname\", \".*\")\nor\nlabel_replace((max_over_time(gpu_prof_pipe_tensor_active_ratio_max{hostname=~\"$hostname\", gpu_index=~\"$gpu\"}[$__range])), \"kpi\", \"max_tensor_active_ratio\", \"hostname\", \".*\")\nor\nlabel_replace((increase(gpu_energy_joules_total{hostname=~\"$hostname\", gpu_index=~\"$gpu\"}[$__range]) / 3600000), \"kpi\", \"energy_kwh\", \"hostname\", \".*\")\nor\nlabel_replace((increase(gpu_energy_joules_total{hostname=~\"$hostname\", gpu_index=~\"$gpu\"}[$__range]) / $__range_s), \"kpi\", \"avg_power_watts\", \"hostname\", \".*\")\nor\nlabel_replace((max_over_time(gpu_power_draw_watts_max{hostname=~\"$hostname\", gpu_index=~\"$gpu\"}[$__range])), \"kpi\", \"max_power_watts\", \"hostname\", \".*\")\nor\nlabel_replace((max_over_time(gpu_temperature_celsius_max{hostname=~\"$hostname\", gpu_index=~\"$gpu\"}[$__range])), \"kpi\", \"max_temperature_celsius\", \"hostname\", \".*\")\nor\nlabel_replace((max_over_time(gpu_framebuffer_memory_used_percent_max{hostname=~\"$hostname\", gpu_index=~\"$gpu\"}[$__range])), \"kpi\", \"max_framebuffer_used_percent\", \"hostname\", \".*\")",
          "legendFormat": "",
          "range": false,
          "refId": "A",
          "instant": true,
          "format": "table"
        }
      ]
